{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": "container",
  "height": "container",
  "padding": 2,
  "data": {
    "name": "dashboardData"
  },
  "params": [
    { "name": "is_cumulative", "value": true },
    { "name": "year", "value": "overall" }
  ],
  "transform": [
    { "filter": "year === 'overall' || year(datum.date) === year" },
    {
      "window": [{ "op": "sum", "field": "count", "as": "cumulative" }],
      "sort": [{ "field": "date" }]
    },
    {
      "calculate": "is_cumulative ? datum.cumulative : datum.count",
      "as": "metric_value"
    },
    {
      "calculate": "month(datum.date)",
      "as": "month_index"
    },
    {
      "calculate": "datum.month_index === 0 ? 'Gen' : datum.month_index === 1 ? 'Feb' : datum.month_index === 2 ? 'Mar' : datum.month_index === 3 ? 'Apr' : datum.month_index === 4 ? 'Mag' : datum.month_index === 5 ? 'Giu' : datum.month_index === 6 ? 'Lug' : datum.month_index === 7 ? 'Ago' : datum.month_index === 8 ? 'Set' : datum.month_index === 9 ? 'Ott' : datum.month_index === 10 ? 'Nov' : 'Dic'",
      "as": "month_name"
    },
    {
      "calculate": "datum.month_index === 0 ? 'gennaio' : datum.month_index === 1 ? 'febbraio' : datum.month_index === 2 ? 'marzo' : datum.month_index === 3 ? 'aprile' : datum.month_index === 4 ? 'maggio' : datum.month_index === 5 ? 'giugno' : datum.month_index === 6 ? 'luglio' : datum.month_index === 7 ? 'agosto' : datum.month_index === 8 ? 'settembre' : datum.month_index === 9 ? 'ottobre' : datum.month_index === 10 ? 'novembre' : 'dicembre'",
      "as": "month_full"
    },
    {
      "calculate": "year(datum.date)",
      "as": "year_label"
    },
    {
      "calculate": "'tipo di valore: ' + (is_cumulative ? 'cumulato' : 'mensile') + '; mese: ' + datum.month_full + '; anno: ' + datum.year_label + '; messaggi inviati: ' + format(datum.metric_value, ',')",
      "as": "custom_aria_label"
    }
  ],
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "timeUnit": "yearmonth",
      "axis": {
        "gridDash": [6, 6],
        "grid": true,
        "gridColor": "#D2D6E3",
        "labelAngle": 0,
        "labelFontWeight": 600,
        "labelFont": "titilliumWeb",
        "tickDash": [4, 4],
        "title": null,
        "format": "%b",
        "tickCount": 12
      }
    },
    "tooltip": [
      { "field": "month_name" },
      { "field": "year_label" },
      { "field": "metric_value", "format": "," }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "aria": false,
        "line": { "color": "#0B3EE3" },
        "color": {
          "x1": 1,
          "y1": 1,
          "x2": 1,
          "y2": 0,
          "stops": [
            { "offset": 0, "color": "white" },
            { "offset": 1, "color": "#0B3EE3" }
          ],
          "gradient": "linear"
        }
      },
      "encoding": {
        "y": {
          "field": "metric_value",
          "type": "quantitative",
          "axis": {
            "format": "~s",
            "labelFontWeight": 600,
            "labelFont": "titilliumWeb",
            "domain": false
          }
        }
      }
    },
    {
      "mark": { "type": "point", "opacity": 0, "size": 200 },
      "encoding": {
        "y": { "field": "metric_value", "type": "quantitative" },
        "description": {
          "field": "custom_aria_label",
          "type": "nominal"
        }
      }
    }
  ]
}
